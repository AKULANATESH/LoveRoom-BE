# Local Docker Postgres (see docker-compose.yml)
POSTGRES_USER=nani
POSTGRES_PASSWORD=password
POSTGRES_DB=together_db

# Prisma — for local, both can point at the same DB.
# On Supabase + Render (IPv4): use the POOLER URLs from
# Supabase → Project Settings → Database → Connection string → "Transaction" / "Session"
# Direct db.*.supabase.co:5432 often fails from Render (IPv6-only).
#
# Example (password must be URL-encoded; @ -> %40):
# DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
# DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?schema=public"
DATABASE_URL="postgresql://nani:password@localhost:54320/together_db?schema=public"
DIRECT_URL="postgresql://nani:password@localhost:54320/together_db?schema=public"

JWT_SECRET=together-dev-secret-change-in-production

# Comma-separated extra CORS origins (Firebase Hosting URLs in production)
# Localhost 5173/5174 are always allowed.
CORS_ORIGINS=

# Resend (partner setup / reset-password emails)
RESEND_API_KEY=
EMAIL_FROM=LoveRoom <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173

# Render sets PORT automatically; optional for local
# PORT=3000
