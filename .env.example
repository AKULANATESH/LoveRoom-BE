# Local Docker Postgres (see docker-compose.yml)
POSTGRES_USER=nani
POSTGRES_PASSWORD=password
POSTGRES_DB=together_db

# Prisma — for local, both can point at the same DB.
# On Supabase: DATABASE_URL = pooler (:6543), DIRECT_URL = direct (:5432)
DATABASE_URL="postgresql://nani:password@localhost:54320/together_db?schema=public"
DIRECT_URL="postgresql://nani:password@localhost:54320/together_db?schema=public"

JWT_SECRET=together-dev-secret-change-in-production

# Comma-separated extra CORS origins (Firebase Hosting URLs in production)
# Localhost 5173/5174 are always allowed.
CORS_ORIGINS=

# Render sets PORT automatically; optional for local
# PORT=3000
